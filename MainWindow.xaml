<Window x:Class="MidiServiceRestarter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MIDI Service Restarter" Height="540" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"
        Icon="app_icon.png">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Windows MIDI Service Restarter"
                   FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <!-- Service Status + Button -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Please close all DAW and MIDI applications before restarting."
                       Foreground="#D83B01" FontWeight="SemiBold" FontSize="12"
                       Margin="0,0,0,10" HorizontalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="Checking..." FontSize="14"
                       Margin="0,0,0,10" HorizontalAlignment="Center"
                       TextAlignment="Center" Width="440"/>
            <Button x:Name="RestartButton" Content="Restart Service" Width="200" Height="38"
                    FontSize="14" FontWeight="Bold" Background="#0078D7" Foreground="White"
                    Click="RestartButton_Click" Cursor="Hand" Margin="0,0,0,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- Device List Section Header -->
        <Grid Grid.Row="2" Margin="0,18,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="MIDI Device List" FontSize="13" FontWeight="SemiBold"/>
                <CheckBox x:Name="AutoUpdateCheckBox" Content="Auto update (5s)" IsChecked="True" 
                          FontSize="11" Foreground="#666" Margin="8,2,0,0" VerticalAlignment="Center"
                          Checked="AutoUpdateCheckBox_Checked" Unchecked="AutoUpdateCheckBox_Unchecked"/>
            </StackPanel>
            <TextBlock x:Name="LastUpdatedText" Grid.Column="1"
                       Text="Last Updated: --" FontSize="11" Foreground="#666"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Device ListView -->
        <Border Grid.Row="3" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4">
            <ListView x:Name="DeviceListView" BorderThickness="0" Background="White"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Device Name" Width="380"
                                        DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Direction" Width="70"
                                        DisplayMemberBinding="{Binding Direction}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Footer: device count + refresh buttons -->
        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="DeviceCountText" Text="0 devices detected"
                       FontSize="11" Foreground="#555" VerticalAlignment="Center"/>
            <Button x:Name="RefreshButton" Grid.Column="2" Content="Refresh Now"
                    Width="110" Height="26" FontSize="11"
                    Background="#E0E0E0" Foreground="#333"
                    Click="RefreshButton_Click" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>
